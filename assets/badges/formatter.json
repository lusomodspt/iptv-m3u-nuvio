{
  "groups": [
    {
      "id": "resolution",
      "name": "Resolution",
      "color": "#00000000",
      "borderColor": "#00000000",
      "isExpanded": false
    },
    {
      "id": "gq",
      "name": "Quality",
      "color": "#27C04F",
      "isExpanded": false,
      "borderColor": "#00000000"
    },
    {
      "id": "video-tech",
      "name": "Video Tech",
      "color": "#00000000",
      "borderColor": "#00000000",
      "isExpanded": false
    },
    {
      "id": "audio-tech",
      "name": "Audio Tech",
      "color": "#00000000",
      "borderColor": "#00000000",
      "isExpanded": false
    }
  ],
  "filters": [
    {
      "id": "4k-ultra-hd",
      "groupId": "resolution",
      "name": "4K Ultra HD",
      "pattern": "(?i)\\b(?:4k|2160[pi]?|3840\\s*x\\s*2160|4096\\s*x\\s*2160)\\b",
      "imageURL": "https://raw.githubusercontent.com/djgenesis/badges/refs/heads/main/badges/uhd.png",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "1080p-full-hd",
      "groupId": "resolution",
      "name": "1080p Full HD",
      "pattern": "(?i)\\b(?:1080[pi]?|fhd|full[\\s._-]?hd|1920\\s*x\\s*1080)\\b",
      "imageURL": "https://raw.githubusercontent.com/djgenesis/badges/refs/heads/main/badges/fhd.png",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "720p-hd",
      "groupId": "resolution",
      "name": "720p HD",
      "pattern": "(?i)\\b(?:720[pi]?|hd720|1280\\s*x\\s*720)\\b",
      "imageURL": "https://raw.githubusercontent.com/djgenesis/badges/refs/heads/main/badges/720p.png",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "480p-sd",
      "groupId": "resolution",
      "name": "480p SD",
      "pattern": "(?i)\\b(?:480[pi]?|sd480|640\\s*x\\s*480|854\\s*x\\s*480)\\b",
      "imageURL": "https://raw.githubusercontent.com/djgenesis/badges/refs/heads/main/badges/480p.png",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "q-r",
      "groupId": "gq",
      "name": "Remux",
      "pattern": "(?i)\\b(?:bd|uhd)?remux\\b",
      "imageURL": "https://cdn.jsdelivr.net/gh/sweatycab/nuvio-minimalist-badges@main/badges/white-remux.svg",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "borderColor": "#FFFFFF",
      "isEnabled": true
    },
    {
      "id": "q-b",
      "groupId": "gq",
      "name": "BluRay",
      "pattern": "(?i)^(?=.*(?:bluray|blu-ray|\\bb[dr][-_. ]?rip\\b|\\bbd(?:25|50|r|mv)?\\b))(?!.*\\b(?:bd|uhd)?remux\\b)",
      "imageURL": "https://cdn.jsdelivr.net/gh/sweatycab/nuvio-minimalist-badges@main/badges/white-bluray.svg",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "borderColor": "#FFFFFF",
      "isEnabled": true
    },
    {
      "id": "q-w",
      "groupId": "gq",
      "name": "WebDL",
      "pattern": "(?i)\\b(?:web[-_. ]?dl|webdl|web(?![-_. ]?rip)\\b)",
      "imageURL": "https://cdn.jsdelivr.net/gh/sweatycab/nuvio-minimalist-badges@main/badges/white-webdl.svg",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "borderColor": "#FFFFFF",
      "isEnabled": true
    },
    {
      "id": "q-w-2",
      "groupId": "gq",
      "name": "WebRip",
      "pattern": "(?i)^(?=.*\\brip\\b|.*\\bweb[-_. ]?rip\\b|.*\\bhd[-_. ]?rip\\b)(?!.*\\b(?:bd|br)[-_. ]?rip\\b)(?!.*\\bdvd[-_. ]?rip\\b)(?!.*\\b(?:hd[-_. ]?)?tc[-_. ]?rip\\b)(?!.*\\b(?:hd[-_. ]?)?ts[-_. ]?rip\\b)(?!.*\\b(?:hd[-_. ]?)?cam[-_. ]?rip\\b)(?!.*\\btc\\b)(?!.*\\btelecine\\b)(?!.*\\bhdtc\\b)(?!.*\\bts\\b)(?!.*\\btelesync\\b)(?!.*\\bhdts\\b)",
      "imageURL": "https://cdn.jsdelivr.net/gh/sweatycab/nuvio-minimalist-badges@main/badges/white-webrip.svg",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "borderColor": "#FFFFFF",
      "isEnabled": true
    },
    {
      "id": "q-hdtv",
      "groupId": "gq",
      "name": "HDTV",
      "pattern": "(?i)\\b(?:hdtv|pdtv|sdtv|dsr)\\b",
      "imageURL": "https://cdn.jsdelivr.net/gh/sweatycab/nuvio-minimalist-badges@main/badges/white-HDTV.svg",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "borderColor": "#FFFFFF",
      "isEnabled": true
    },
    {
      "id": "q-dvdscr",
      "groupId": "gq",
      "name": "DVDScr",
      "pattern": "(?i)\\bdvd[\\s._-]?scr(?:eener)?\\b",
      "imageURL": "https://cdn.jsdelivr.net/gh/sweatycab/nuvio-minimalist-badges@main/badges/white-DVDScr.svg",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "borderColor": "#FFFFFF",
      "isEnabled": true
    },
    {
      "id": "q-dvdrip",
      "groupId": "gq",
      "name": "DVDRip",
      "pattern": "(?i)^(?=.*\\bdvd[\\s._-]?rip\\b)(?!.*\\bdvd[\\s._-]?scr)",
      "imageURL": "https://cdn.jsdelivr.net/gh/sweatycab/nuvio-minimalist-badges@main/badges/white-DVDRip.svg",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "borderColor": "#FFFFFF",
      "isEnabled": true
    },
    {
      "id": "q-cam",
      "groupId": "gq",
      "name": "CAM",
      "pattern": "(?i)^(?=.*(?:\\b(?:hd[-_. ]?)?cam(?:[-_. ]?rip)?\\b|\\b(?:hd[-_. ]?)?ts(?:[-_. ]?rip)?\\b|\\btelesync\\b|\\bp(?:re[\\s._-]?)?dvd(?:rip)?\\b|\\b(?:hd[-_. ]?)?tc(?:[-_. ]?rip)?\\b|\\btelecine\\b|(?<!dvd)(?<!dvd[._-])\\bscr(?:eener)?\\b))(?!.*\\bdvd[\\s._-]?scr)",
      "imageURL": "https://cdn.jsdelivr.net/gh/sweatycab/nuvio-minimalist-badges@main/badges/white-CAM.svg",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "borderColor": "#FFFFFF",
      "isEnabled": true
    },
    {
      "id": "dolby-vision",
      "groupId": "video-tech",
      "name": "Dolby Vision",
      "pattern": "(?i)\\b(dolby\\s*vision|dovi|dv)\\b",
      "imageURL": "https://raw.githubusercontent.com/leonevz/Elite-Badges/main/Badges/dolby_vision.png",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "hdr10-plus",
      "groupId": "video-tech",
      "name": "HDR10+",
      "pattern": "(?i)\\b(hdr10\\+|hdr10\\s*plus\\b|hdr\\s*10\\s*\\+)",
      "imageURL": "https://raw.githubusercontent.com/leonevz/Elite-Badges/main/Badges/hdr10_plus.png",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "hdr10",
      "groupId": "video-tech",
      "name": "HDR10",
      "pattern": "(?i)\\b(hdr10|hdr\\s*10)\\b(?!\\s*\\+|\\s*plus)",
      "imageURL": "https://raw.githubusercontent.com/leonevz/Elite-Badges/main/Badges/hdr10.png",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "hdr",
      "groupId": "video-tech",
      "name": "HDR",
      "pattern": "(?i)\\bhdr\\b(?!\\s*10)",
      "imageURL": "https://cdn.xperience-app.com/badges/golden_animated/15.webp?v=2",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "sdr",
      "groupId": "video-tech",
      "name": "SDR",
      "pattern": "(?i)\\b(?:sdr)\\b",
      "imageURL": "https://cdn.xperience-app.com/badges/golden_animated/16.webp?v=2",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "imax-enhanced",
      "groupId": "video-tech",
      "name": "IMAX Enhanced",
      "pattern": "(?i)\\b(imax[\\s._-]*enhanced)\\b",
      "imageURL": "https://cdn.xperience-app.com/badges/xp_white/imax-enhanced.webp?v=7",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "imax",
      "groupId": "video-tech",
      "name": "IMAX",
      "pattern": "(?i)\\b(imax)\\b(?![\\s._-]*enhanced)",
      "imageURL": "https://raw.githubusercontent.com/leonevz/Elite-Badges/main/Badges/imax.png",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "dolby-atmos",
      "groupId": "audio-tech",
      "name": "Dolby Atmos",
      "pattern": "(?i)\\b(dolby\\s*atmos|atmos)\\b",
      "imageURL": "https://raw.githubusercontent.com/leonevz/Elite-Badges/main/Badges/dolby_atmos.png",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    },
    {
      "id": "truehd",
      "groupId": "audio-tech",
      "name": "TrueHD",
      "pattern": "(?i)\\b(truehd|true\\s*hd|dolby\\s*truehd)\\b",
      "imageURL": "https://cdn.xperience-app.com/badges/voidxo_starter/truehd.webp",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": true
    }
  ]
}
