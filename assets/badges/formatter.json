  "filters": [
    {
      "id": "4k-ultra-hd",
      "groupId": "resolution",
      "name": "4K Ultra HD",
      "pattern": "(?i)\\b(?:4k|2160[pi]?|3840\\s*x\\s*2160|4096\\s*x\\s*2160)\\b",
      "imageURL": "https://raw.githubusercontent.com/djgenesis/badges/refs/heads/main/badges/uhd.png",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#00000000",
      "borderColor": "#00000000",
      "isEnabled": false
    },
    {
      "id": "1080p-full-hd",
